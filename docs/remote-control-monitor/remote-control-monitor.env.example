# Remote Control Monitor — variáveis de ambiente
# Copie pra ~/.claude/remote-control-monitor.env e ajuste.
# Permissão recomendada: chmod 600

# Toggle de notificações WhatsApp quando o monitor executa ação de connect.
# Valores: true | false (padrão: true)
WHATSAPP_ENABLED=false

# Prefixo de ambiente pro nome do Remote Control.
# Define identidade do ambiente no claude.ai/code:
#   cs   → servidor compartilhado
#   mac  → MacBook local
#   wsl  → WSL Windows
# Deixe vazio APENAS se for o único ambiente rodando.
CLAUDE_ENV_PREFIX=
