# Remote Control Monitor — variáveis de ambiente
# Copiar pra ~/.claude/remote-control-monitor.env e ajustar os valores.
# Permissão recomendada: chmod 600

# Toggle de notificações WhatsApp quando o monitor executa ação de connect.
# Valores: true | false   (default no script: true)
WHATSAPP_ENABLED=true

# Prefixo de ambiente adicionado ao nome do Remote Control.
# OBRIGATÓRIO ser diferente em cada ambiente que roda o monitor — senão
# as sessões colidem no claude.ai/code.
#
# Exemplos sugeridos:
#   cs   → servidor compartilhado (ubuntu-claude-agents)
#   mac  → máquina local macOS
#   wsl  → Windows Subsystem for Linux
#   lin  → Linux desktop
#   lab  → ambiente de testes
#
# Deixe vazio APENAS se tiver certeza que é o único ambiente rodando.
CLAUDE_ENV_PREFIX=SEU_PREFIXO_AQUI
