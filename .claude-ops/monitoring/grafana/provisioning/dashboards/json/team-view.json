{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Consumo de CPU e RAM por projeto — comparativo entre todos os 6 projetos ativos",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Agentes Ativos por Projeto",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "value"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "claude_project:agent_count:sum",
          "legendFormat": "{{project}}",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 10,
      "title": "CPU por Projeto — agora (%)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "expr": "sum by (project) (rate(claude_agent_cpu_user_seconds_total[1m]) + rate(claude_agent_cpu_system_seconds_total[1m]))",
          "legendFormat": "{{project}}",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 11,
      "title": "RAM por Projeto — agora (MB)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2048 },
              { "color": "red", "value": 6144 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "expr": "sum by (project) (claude_agent_memory_rss_bytes) / 1024 / 1024",
          "legendFormat": "{{project}}",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 20,
      "title": "CPU por Projeto — Histórico (%)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (project) (rate(claude_agent_cpu_user_seconds_total[1m]) + rate(claude_agent_cpu_system_seconds_total[1m]))",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 21,
      "title": "RAM por Projeto — Histórico (MB)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (project) (claude_agent_memory_rss_bytes) / 1024 / 1024",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 30,
      "title": "CPU Acumulada por Projeto (user+system) — stacked",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (project) (rate(claude_agent_cpu_user_seconds_total[1m]) + rate(claude_agent_cpu_system_seconds_total[1m]))",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 40,
      "title": "RAM Acumulada por Projeto — stacked (MB)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (project) (claude_agent_memory_rss_bytes) / 1024 / 1024",
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "tags": ["claude", "projects", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
