{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Consumo de CPU e RAM por agente, separado por projeto — label composto project/agent",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Agentes Ativos",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "custom": { "align": "left", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "project" },
            "properties": [
              { "id": "displayName", "value": "Projeto" },
              { "id": "custom.width", "value": 220 },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "agent" },
            "properties": [
              { "id": "displayName", "value": "Agente" },
              { "id": "custom.width", "value": 250 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Processos" },
              { "id": "custom.width", "value": 100 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Projeto", "desc": false }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "expr": "count by (project, agent) (claude_agent_info)",
          "legendFormat": "{{project}} / {{agent}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": {}
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "displayName": "project", "desc": false }] }
        }
      ]
    },

    {
      "id": 10,
      "title": "CPU por Agente — Histórico (%) — legenda: projeto / agente",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (project, agent) (rate(claude_agent_cpu_user_seconds_total[1m]) + rate(claude_agent_cpu_system_seconds_total[1m]))",
          "legendFormat": "{{project}} / {{agent}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 11,
      "title": "RAM por Agente — Histórico (MB) — legenda: projeto / agente",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (project, agent) (claude_agent_memory_rss_bytes) / 1024 / 1024",
          "legendFormat": "{{project}} / {{agent}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 20,
      "title": "CPU por Agente — agora (bargauge)",
      "type": "bargauge",
      "gridPos": { "h": 14, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "expr": "sum by (project, agent) (rate(claude_agent_cpu_user_seconds_total[1m]) + rate(claude_agent_cpu_system_seconds_total[1m]))",
          "legendFormat": "{{project}} / {{agent}}",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 21,
      "title": "RAM por Agente — agora (bargauge, MB)",
      "type": "bargauge",
      "gridPos": { "h": 14, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400 },
              { "color": "red", "value": 800 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "expr": "sum by (project, agent) (claude_agent_memory_rss_bytes) / 1024 / 1024",
          "legendFormat": "{{project}} / {{agent}}",
          "refId": "A",
          "instant": true
        }
      ]
    },

    {
      "id": 30,
      "title": "CPU por Projeto — stacked (todos os agentes)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (project, agent) (rate(claude_agent_cpu_user_seconds_total[1m]) + rate(claude_agent_cpu_system_seconds_total[1m]))",
          "legendFormat": "{{project}} / {{agent}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 31,
      "title": "RAM por Projeto — stacked (todos os agentes, MB)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "sum by (project, agent) (claude_agent_memory_rss_bytes) / 1024 / 1024",
          "legendFormat": "{{project}} / {{agent}}",
          "refId": "A"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "tags": ["claude", "agents", "per-project"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Consumo por Agente Claude",
  "uid": "claude-agents-001",
  "version": 2
}
