# .env — configurações do .claude-ops (preencha antes de rodar install.sh)

# ── Caminhos ──────────────────────────────────────────────────────────
# Onde clonar/usar o repo mcp-servers (default: ~/mcp-servers)
MCP_ROOT="$HOME/mcp-servers"

# Diretório textfile_collector do node_exporter
# Linux: /var/lib/node_exporter/textfile_collector
# macOS: /usr/local/var/node_exporter/textfile_collector
# (será detectado automaticamente se vazio)
TEXTFILE_DIR=""

# ── Claude Code ──────────────────────────────────────────────────────
# Caminho do binário claude (será detectado via 'command -v' se vazio)
CLAUDE_BIN=""

# Aguarda Claude inicializar antes de injetar /team-protocol (segundos)
CLAUDE_INIT_WAIT="15"

# Delay entre agentes no start-all (evita load alto no boot)
START_ALL_DELAY="5"

# ── WhatsApp alerting (Evolution API) ─────────────────────────────────
EVOLUTION_API_URL="https://evolution.inoveon.com.br"
EVOLUTION_API_KEY="REPLACE_ME"
EVOLUTION_DEFAULT_INSTANCE="REPLACE_ME"

# Número que recebe alertas do remote-control-monitor (formato: 5511999999999)
WHATSAPP_NUMBER="REPLACE_ME"

# ── PostgreSQL para i9-agent-memory ───────────────────────────────────
POSTGRES_USER="agent"
POSTGRES_PASSWORD="agent123"
POSTGRES_DB="agent_memory"
POSTGRES_PORT="5432"

# ── OpenAI/OpenRouter para embeddings ────────────────────────────────
OPENAI_API_KEY="REPLACE_ME"
EMBEDDING_BASE_URL="https://openrouter.ai/api/v1"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS="1536"

# ── Grafana (admin inicial) ──────────────────────────────────────────
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin123"

# ── APIs Inoveon (opcionais, só se configurar MCPs PDV/Service) ──────
PDV_API_URL="http://10.0.10.3:4001"
PDV_EMAIL="admin@inoveon.com.br"
PDV_PASSWORD="REPLACE_ME"
CNPJ_API_URL="http://10.0.10.3:4006"
DFE_API_URL="http://10.0.10.3:4003"
KNOWLEDGE_API_URL="http://10.0.10.16:3500"
SMARTPASS_API_URL="http://10.0.10.3:4014"
VIEW_API_URL="http://10.0.10.3:4011"
VIEW_EMAIL="admin@inoveon.com.br"
VIEW_PASSWORD="REPLACE_ME"
