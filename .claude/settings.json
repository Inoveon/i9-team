{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Read",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__i9-team__*",
      "mcp__i9-agent-memory__*",
      "mcp__evolution-api__*",
      "mcp__db-manager__*",
      "mcp__plugin_context-mode_context-mode__*",
      "mcp__plugin_telegram_telegram__*"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(docker system prune*)"
    ]
  }
}
